    font-family: var(--font-mono);
    color: var(--text-muted);
    margin-top: 1.25rem;
    margin-bottom: 0;
  }

  .soon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
</style>
