<style>
  .portfolio {
    padding: 6rem 4rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .accent-bar {
    width: 48px;
    height: 3px;
    background: var(--accent-dark);
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .intro {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-soft);
    max-width: 680px;
    margin-bottom: 4rem;
  }

  .project-list { display: flex; flex-direction: column; gap: 1.5rem; }

  .project-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.25rem;
  }

  .project-card.live {
    border-color: rgba(96, 165, 250, 0.2);
    background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, var(--surface-card) 50%);
  }

  .project-card.soon { opacity: 0.72; }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .card-meta { display: flex; align-items: center; gap: 0.75rem; }

  .project-number {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-mono);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .status-badge.live {
    background: rgba(16, 185, 129, 0.15);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #34d399;
  }

  .status-badge.soon {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted);
  }

  h3 {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .tagline {
    font-size: 0.95rem;
    color: var(--accent);
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-soft);
    margin-bottom: 1rem;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .card-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.55rem 1.25rem;
    border-radius: 6px;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .link-btn.primary {
    background: var(--accent-dark);
    color: var(--text);
  }

  .link-btn.primary:hover { background: #1d4ed8; }

  .link-btn.secondary {
    background: transparent;
    color: var(--text-soft);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .link-btn.secondary:hover {
    border-color: rgba(255,255,255,0.3);
    color: var(--text);
  }

  .access-note {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-muted);
    font-style: italic;
