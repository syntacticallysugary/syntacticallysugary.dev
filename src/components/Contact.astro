---
---

<section class="contact" id="contact">
  <div class="eyebrow">Contact</div>
  <div class="accent-bar"></div>
  <h2>Let's Talk</h2>
  <p class="intro">
    Whether you have a specific project in mind or just want to explore what's possible,
    I'm happy to have the conversation.
  </p>

  <form class="contact-form" name="contact" method="POST">
    <div class="field-group">
      <div class="field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Your name" required />
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="your@email.com" required />
      </div>
    </div>
    <div class="field">
      <label for="message">What are you working on?</label>
      <textarea id="message" name="message" rows="5" placeholder="Tell me about your project or challenge..." required></textarea>
    </div>
    <button type="submit" class="submit-btn">Send Message</button>
  </form>
</section>

<style>
  .contact {
    padding: 6rem 4rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .accent-bar {
    width: 48px;
    height: 3px;
    background: var(--accent-dark);
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-soft);
    margin-bottom: 3rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-soft);
  }

  input, textarea {
    background: var(--surface-card);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  input::placeholder, textarea::placeholder { color: var(--text-muted); }

  input:focus, textarea:focus {
    border-color: var(--accent-dark);
  }

  .submit-btn {
    align-self: flex-start;
    background: var(--accent-dark);
    color: var(--text);
    font-size: 0.925rem;
    font-weight: 600;
    font-family: var(--font-sans);
    padding: 0.8rem 2rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .submit-btn:hover { background: #1d4ed8; }
</style>
